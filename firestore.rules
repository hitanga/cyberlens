rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Hardcoded admin for this project context
      return isSignedIn() && request.auth.token.email == 'gopalzone2025@gmail.com' && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isAdmin() && 
        request.resource.data.keys().hasAll(['title', 'category', 'content', 'image', 'date']) &&
        request.resource.data.title is string && request.resource.data.title.size() < 200;
      allow update: if (isAdmin()) || (
        isSignedIn() && 
        // Ensure we are only updating the likes field
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']) &&
        // Ensure types remain consistent
        request.resource.data.likes is number
      );
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && 
          request.resource.data.keys().hasAll(['user', 'content', 'time']) &&
          request.resource.data.content.size() < 500;
      }
    }

    match /subscribers/{subscriberId} {
      allow create: if request.resource.data.keys().hasAll(['email', 'timestamp']) &&
        request.resource.data.email is string &&
        request.resource.data.email.size() < 256;
      allow read, update, delete: if isAdmin();
    }
  }
}
